// This is your Prisma schema file.
// It defines the shape of your database tables and their relationships.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())

  // ── Phase 5: Philosopher's Profile ────────────────────────────────────────
  inscription         String?  // The Philosopher's Inscription
  epigraph            String?  // The Stoa (personal epigraph)
  intellectualLineage Json?    // [{name, url?}] ordered array
  epistemicStance     Json?    // {reasonFrom?, holdBeliefs?, uncertainAbout?}
  intellectualSeasons Json?    // [{period, description}] ordered array
  unresolvedQuestions Json?    // [string] ordered array
  profilePublic       Boolean  @default(true)

  ideas    Idea[]
  tags     Tag[]
  projects Project[]
  vestiges Vestige[]
  discussionPosts DiscussionPost[]
}

// ─── Idea ─────────────────────────────────────────────────────────────────────
model Idea {
  id                 String             @id @default(cuid())
  title              String
  body               Json?
  status             IdeaStatus         @default(SEED)
  contentHash        String?
  verificationStatus VerificationStatus @default(UNVERIFIED)
  publishedAt        DateTime?          // Set once on first transition to PUBLISHED
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tags               IdeaTag[]
  linksFrom          IdeaLink[]          @relation("LinkFrom")
  linksTo            IdeaLink[]          @relation("LinkTo")
  projects           IdeaProject[]
  verificationEvents VerificationEvent[]
  reactions          Reaction[]

  @@index([userId])
  @@index([status])
  @@index([verificationStatus])
}

enum IdeaStatus {
  SEED
  GROWING
  PUBLISHED
}

enum VerificationStatus {
  UNVERIFIED
  REVIEW
  VERIFIED
  FLAGGED
}

// ─── Tag ─────────────────────────────────────────────────────────────────────
model Tag {
  id     String    @id @default(cuid())
  name   String
  slug   String

  userId String
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  ideas  IdeaTag[]

  @@unique([slug, userId])
}

// ─── IdeaTag ──────────────────────────────────────────────────────────────────
model IdeaTag {
  ideaId String
  tagId  String

  idea Idea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId],  references: [id], onDelete: Cascade)

  @@id([ideaId, tagId])
}

// ─── IdeaLink ─────────────────────────────────────────────────────────────────
model IdeaLink {
  fromIdeaId String
  toIdeaId   String

  fromIdea Idea @relation("LinkFrom", fields: [fromIdeaId], references: [id], onDelete: Cascade)
  toIdea   Idea @relation("LinkTo",   fields: [toIdeaId],   references: [id], onDelete: Cascade)

  @@id([fromIdeaId, toIdeaId])
}

// ─── Project ─────────────────────────────────────────────────────────────────
// A named workbench that groups related ideas and reference files.
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ideas IdeaProject[]
  files ProjectFile[]

  @@index([userId])
}

// ─── IdeaProject ─────────────────────────────────────────────────────────────
model IdeaProject {
  ideaId    String
  projectId String

  idea    Idea    @relation(fields: [ideaId],    references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([ideaId, projectId])
}

// ─── ProjectFile ─────────────────────────────────────────────────────────────
// A reference file uploaded to a Project workbench.
model ProjectFile {
  id         String   @id @default(cuid())
  filename   String
  mimeType   String
  storageUrl String
  sizeBytes  Int?
  uploadedAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─── VerificationEvent ────────────────────────────────────────────────────────
// Audit trail for every originality check performed on an Idea.
model VerificationEvent {
  id        String             @id @default(cuid())
  status    VerificationStatus
  reason    String?
  createdAt DateTime           @default(now())

  ideaId String
  idea   Idea   @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([ideaId])
}

// ─── Reaction ─────────────────────────────────────────────────────────────────
// Anonymous emoji reactions from Agora readers. No auth required to create.
model Reaction {
  id        String   @id @default(cuid())
  ideaId    String
  emoji     String   // e.g. "💡", "🔥", "🌱"
  createdAt DateTime @default(now())

  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@index([ideaId])
}

// ─── Vestige ─────────────────────────────────────────────────────────────────
// A private record of an idea that was deliberately reconsidered and removed.
model Vestige {
  id             String    @id @default(cuid())
  title          String
  reconsideredAt DateTime  @default(now())
  reflection     String?
  reflectionAt   DateTime?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Discussion ───────────────────────────────────────────────────────────────
// A public thread seeded from an Unresolved Question or opened freely.
// Only authenticated users can post; anyone can read.
model Discussion {
  id        String   @id @default(cuid())
  prompt    String   // The opening question or proposition
  sourceUrl String?  // Optional: URL of the originating idea or profile
  createdAt DateTime @default(now())

  posts DiscussionPost[]

  @@index([createdAt])
}

// ─── DiscussionPost ───────────────────────────────────────────────────────────
// An individual reply in a Discussion thread. Author is always a User.
model DiscussionPost {
  id           String   @id @default(cuid())
  body         String   // Plain text, max ~2000 chars
  createdAt    DateTime @default(now())

  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([discussionId])
  @@index([userId])
}
