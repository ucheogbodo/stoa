# ─────────────────────────────────────────────────────────────────────────────
# .env.local — local environment variables (NEVER commit this file to git)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────────
# Your Supabase PostgreSQL connection string.
# Find it at: Supabase Dashboard → Settings → Database → Connection string → URI
# Make sure to replace [YOUR-PASSWORD] with your actual database password.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# A random secret used to sign JWTs. Generate one with:
#   openssl rand -base64 32
# Or online at: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="REPLACE_WITH_A_RANDOM_SECRET"

# The URL where your app is running (used by NextAuth for redirects)
NEXTAUTH_URL="http://localhost:3000"

# ── Seed Script ───────────────────────────────────────────────────────────────
# Credentials for the initial admin user (used only by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@stoa.local"
SEED_ADMIN_PASSWORD="changeme123"
SEED_ADMIN_NAME="Admin"
